# Dcard Crawler Settings

# API Configuration
DCARD_API_BASE_URL: "https://www.dcard.tw/service/api/v2"
DCARD_FORUM_ALIAS: "trending"
DCARD_BASE_URL: "https://www.dcard.tw"
DCARD_SSL_VERIFY: "false"  # Set false for self-signed cert environments

# Rate Limiting
API_RATE_LIMIT_PER_SECOND: 2
DETAIL_RATE_LIMIT_PER_SECOND: 1
BATCH_SIZE: 100
BATCH_REST_INTERVAL: 5

# Retry Settings
MAX_RETRIES: 3
RETRY_BACKOFF_FACTOR: 2

# Database
DATABASE_URL: "sqlite:///data/dcard_crawler.db"

# Logging
LOG_LEVEL: "INFO"
LOG_FILE: "logs/crawler.log"

# Checkpoint
CHECKPOINT_FILE: "data/checkpoint.json"
